      "interval": {
        "distribution": "uniform",
        "min": "10ms",
        "max": "25ms"
      },
      "fee": "0.00001000",
      "funding_threshold": "0.20001000"
    },
    {
      "type": "wallet_transactions",
      "strategy": "hotspot",
      "receiver_wallets": [2, 4],
      "transaction_count": 8,
      "amount": {
        "distribution": "fixed",
        "min": "0.15000000",
        "max": "0.15000000"
      },
      "interval": "15ms",
      "fee": "0.00001000"
    }
  ]
